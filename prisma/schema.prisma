// # Define the complete schema content to be stored in a file and embedded cleanly
// schema_content = """// ============================================
// // GENERATOR & DATABASE CONFIGURATION
// // ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum UserRole {
  ADMIN
  MANAGER
  STOREKEEPER
  ACCOUNTANT
  DISTRIBUTOR
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
}

enum ModuleName {
  PRODUCTS
  INVENTORY
  PURCHASES
  SALES
  CUSTOMERS
  SUPPLIERS
  PRODUCTION
  WORKERS
  ACCOUNTING
  REPORTS
}

enum ProductType {
  RAW_CHARCOAL
  PACKAGED_CHARCOAL
  OTHER
}

enum MovementType {
  PURCHASE
  PRODUCTION_CONSUME
  PRODUCTION_OUTPUT
  SALE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
}

enum TransferStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

enum LedgerType {
  DEBIT
  CREDIT
}

enum BatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

// enum OrderStatus {
//   PENDING
//   COMPLETED
//   CANCELLED
// }

// enum InvoiceStatus {
//   UNPAID
//   PARTIALLY_PAID
//   PAID
// }

// ============================================
// AUTH & USERS SYSTEM
// ============================================

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  phone     String?
  avatar    String?
  role      UserRole   @default(DISTRIBUTOR)
  status    UserStatus @default(ACTIVE)
  lastLogin DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  permissions   UserPermission[]
  locations     UserLocation[]
  auditLogs     AuditLog[]
  syncRecords   SyncQueue[]
  movements     StockMovement[]
  transfersFrom StockTransfer[]  @relation("TransferredBy")
  salesOrders   SalesOrder[]
  invoices      Invoice[]
  payments      Payment[]
  expenses      Expense[]

  @@index([email])
  @@map("users")
}

model Permission {
  id        String           @id @default(uuid())
  role      UserRole
  module    ModuleName
  action    PermissionAction
  createdAt DateTime         @default(now())
  users     UserPermission[]

  @@unique([role, module, action])
  @@map("permissions")
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

// ============================================
// INVENTORY & WAREHOUSES
// ============================================

model Warehouse {
  id        String   @id @default(uuid())
  name      String
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks            Stock[]
  movements         StockMovement[]
  transfersFrom     StockTransfer[]   @relation("FromWarehouse")
  transfersTo       StockTransfer[]   @relation("ToWarehouse")
  productionBatches ProductionBatch[] @relation("BatchWarehouse")
  purchaseInvoices  PurchaseInvoice[]
  salesOrders       SalesOrder[]

  @@map("warehouses")
}

model Product {
  id           String      @id @default(uuid())
  name         String
  nameAr       String
  type         ProductType
  sku          String      @unique
  image        String?
  weight       Decimal?    @db.Decimal(12, 3)
  purchaseCost Decimal?    @db.Decimal(12, 2)
  sellingPrice Decimal?    @db.Decimal(12, 2)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  stocks                Stock[]
  movements             StockMovement[]
  transferItems         StockTransferItem[]
  productionOutputs     ProductionOutput[]
  productionConsumables ProductionConsumption[]
  salesItems            SalesOrderItem[]
  purchaseInvoiceItems  PurchaseInvoiceItem[]

  @@map("products")
}

model Stock {
  id          String   @id @default(uuid())
  warehouseId String
  productId   String
  quantity    Decimal  @db.Decimal(12, 3)
  updatedAt   DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@map("stocks")
}

model StockMovement {
  id          String       @id @default(uuid())
  productId   String
  warehouseId String
  type        MovementType
  quantity    Decimal      @db.Decimal(12, 3)
  notes       String?
  referenceId String?
  createdById String
  createdAt   DateTime     @default(now())

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id])

  @@map("stock_movements")
}

model StockTransfer {
  id              String         @id @default(uuid())
  transferNumber  String         @unique
  fromWarehouseId String
  toWarehouseId   String
  status          TransferStatus @default(PENDING)
  createdById     String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  fromWarehouse Warehouse           @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse           @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  createdBy     User                @relation("TransferredBy", fields: [createdById], references: [id])
  items         StockTransferItem[]

  @@map("stock_transfers")
}

model StockTransferItem {
  id              String  @id @default(uuid())
  stockTransferId String
  productId       String
  quantity        Decimal @db.Decimal(12, 3)

  transfer StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("stock_transfer_items")
}

// ============================================
// SUPPLIERS & RAW MATERIAL PURCHASES
// ============================================

model Supplier {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseInvoices PurchaseInvoice[]
  ledgerEntries    LedgerEntry[]

  @@map("suppliers")
}

model PurchaseInvoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  supplierId    String
  warehouseId   String
  totalAmount   Decimal  @db.Decimal(12, 2)
  paidAmount    Decimal  @db.Decimal(12, 2)
  invoiceDate   DateTime @default(now())
  createdAt     DateTime @default(now())

  supplier      Supplier              @relation(fields: [supplierId], references: [id])
  warehouse     Warehouse             @relation(fields: [warehouseId], references: [id])
  weightTickets WeightTicket[]
  items         PurchaseInvoiceItem[]

  @@map("purchase_invoices")
}

model PurchaseInvoiceItem {
  id                String  @id @default(uuid())
  purchaseInvoiceId String
  productId         String
  quantity          Decimal @db.Decimal(12, 3)
  unitPrice         Decimal @db.Decimal(12, 2)
  totalPrice        Decimal @db.Decimal(12, 2)

  invoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])

  @@map("purchase_invoice_items")
}

model WeightTicket {
  id                String   @id @default(uuid())
  ticketNumber      String   @unique
  purchaseInvoiceId String
  grossWeight       Decimal  @db.Decimal(12, 3)
  tareWeight        Decimal  @db.Decimal(12, 3)
  netWeight         Decimal  @db.Decimal(12, 3)
  carNumber         String?
  createdAt         DateTime @default(now())

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)

  @@map("weight_tickets")
}

// ============================================
// PRODUCTION MODULE
// ============================================

model ProductionBatch {
  id          String      @id @default(uuid())
  batchNumber String      @unique
  warehouseId String
  status      BatchStatus @default(COMPLETED)

  rawMaterialsCost Decimal @default(0) @db.Decimal(12, 2)
  laborCost        Decimal @default(0) @db.Decimal(12, 2)
  otherCosts       Decimal @default(0) @db.Decimal(12, 2)
  totalBatchCost   Decimal @default(0) @db.Decimal(12, 2)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  warehouse        Warehouse               @relation("BatchWarehouse", fields: [warehouseId], references: [id])
  consumptions     ProductionConsumption[]
  outputs          ProductionOutput[]
  // productivities WorkerProductivity[]
  workerDailyWages WorkerDailyWage[]

  @@map("production_batches")
}

model ProductionConsumption {
  id                String  @id @default(uuid())
  productionBatchId String
  productId         String
  quantity          Decimal @db.Decimal(12, 3)
  unitCost          Decimal @default(0) @db.Decimal(12, 2)
  totalCost         Decimal @default(0) @db.Decimal(12, 2)

  batch   ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("production_consumptions")
}

model ProductionOutput {
  id                String  @id @default(uuid())
  productionBatchId String
  productId         String
  quantity          Decimal @db.Decimal(12, 3)
  waste             Decimal @default(0) @db.Decimal(12, 3)
  costPerUnit       Decimal @default(0) @db.Decimal(12, 2)

  batch   ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("production_outputs")
}

// ============================================
// SALES & CUSTOMERS SYSTEM
// ============================================

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesOrders   SalesOrder[]
  invoices      Invoice[]
  ledgerEntries LedgerEntry[]

  @@map("customers")
}

model SalesOrder {
  id          String      @id @default(uuid())
  orderNumber String      @unique
  customerId  String
  warehouseId String
  createdById String
  totalAmount Decimal     @db.Decimal(12, 2)
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())

  customer  Customer         @relation(fields: [customerId], references: [id])
  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  createdBy User             @relation(fields: [createdById], references: [id])
  items     SalesOrderItem[]
  invoices  Invoice[]

  @@map("sales_orders")
}

model SalesOrderItem {
  id           String  @id @default(uuid())
  salesOrderId String
  productId    String
  quantity     Decimal @db.Decimal(12, 3)
  unitPrice    Decimal @db.Decimal(12, 2)
  totalPrice   Decimal @db.Decimal(12, 2)

  order   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("sales_order_items")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  salesOrderId  String
  customerId    String
  createdById   String
  totalAmount   Decimal       @db.Decimal(12, 2)
  paidAmount    Decimal       @db.Decimal(12, 2)
  status        InvoiceStatus @default(UNPAID)
  createdAt     DateTime      @default(now())

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  customer   Customer   @relation(fields: [customerId], references: [id])
  createdBy  User       @relation(fields: [createdById], references: [id])
  payments   Payment[]

  @@map("invoices")
}

model Payment {
  id            String        @id @default(uuid())
  invoiceId     String
  createdById   String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  notes         String?
  createdAt     DateTime      @default(now())

  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])

  @@map("payments")
}

// ============================================
// HR MODULE (WORKERS & PRODUCTIVITY)
// ============================================
model Worker {
  id               String   @id @default(uuid())
  name             String
  phone            String?
  role             String?
  defaultDailyWage Decimal? @db.Decimal(12, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  attendance Attendance[]
  advances   WorkerAdvance[]
  dailyWages WorkerDailyWage[]

  @@map("workers")
}

model Attendance {
  id        String           @id @default(uuid())
  workerId  String
  date      DateTime         @db.Date
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  createdAt DateTime         @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, date])
  @@map("attendance")
}

model WorkerAdvance {
  id        String   @id @default(uuid())
  workerId  String
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("worker_advances")
}

model WorkerDailyWage {
  id                String   @id @default(uuid())
  workerId          String
  productionBatchId String
  dailyWage         Decimal  @db.Decimal(12, 2)
  notes             String?
  date              DateTime @default(now()) @db.Date

  worker Worker          @relation(fields: [workerId], references: [id], onDelete: Cascade)
  batch  ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)

  @@map("worker_daily_wages")
}

// ============================================
// ACCOUNTING & FINANCIALS
// ============================================

model Expense {
  id          String   @id @default(uuid())
  title       String
  amount      Decimal  @db.Decimal(12, 2)
  category    String
  notes       String?
  createdById String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  createdBy User @relation(fields: [createdById], references: [id])

  @@map("expenses")
}

model LedgerEntry {
  id          String     @id @default(uuid())
  customerId  String?
  supplierId  String?
  amount      Decimal    @db.Decimal(12, 2) // Positive for dues, Negative for payments
  type        LedgerType
  description String?
  createdAt   DateTime   @default(now())

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("ledger_entries")
}

// ============================================
// SYSTEM & OFFLINE INFRASTRUCTURE
// ============================================

model UserLocation {
  id        String   @id @default(uuid())
  userId    String
  latitude  Float
  longitude Float
  accuracy  Float?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_locations")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  tableName String
  recordId  String?
  oldData   Json?
  newData   Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([tableName])
  @@index([recordId])
  @@map("audit_logs")
}

model SyncQueue {
  id        String   @id @default(uuid())
  userId    String?
  tableName String
  recordId  String
  action    String
  payload   Json?
  synced    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([synced])
  @@map("sync_queue")
}
